        self.category_items: dict[str, QTreeWidgetItem] = {}
        self._changing = False
        self.worker: ApplyThread | None = None

        self.setWindowTitle("Linxira 软件中心")
        self.resize(980, 680)
        central = QWidget()
        root = QVBoxLayout(central)
        root.setContentsMargins(22, 18, 22, 18)
        self.setCentralWidget(central)

        heading = QLabel("官方推荐软件")
        heading.setFont(QFont(heading.font().family(), 20, QFont.Weight.DemiBold))
        root.addWidget(heading)
        root.addWidget(QLabel("从经过审核的软件目录中选择应用。展开类别可查看和调整每个项目。"))

        toolbar = QHBoxLayout()
        toolbar.addWidget(QLabel("显示："))
        self.filter_box = QComboBox()
        self.filter_box.addItem("已审核且可安装", "default")
        self.filter_box.addItem("已安装", "installed")
        self.filter_box.addItem("第三方审核频道（仅查看，需 opt-in）", "review")
        self.filter_box.currentIndexChanged.connect(self.apply_filter)
        toolbar.addWidget(self.filter_box)
        toolbar.addStretch()
        root.addLayout(toolbar)

        splitter = QSplitter()
        self.tree = QTreeWidget()
        self.tree.setHeaderLabels(["软件", "状态"])
        self.tree.setColumnWidth(0, 390)
        self.tree.setAlternatingRowColors(True)
        self.tree.setAccessibleName("官方推荐软件选择树")
        self.tree.itemChanged.connect(self.on_item_changed)
        self.tree.currentItemChanged.connect(self.show_details)
        splitter.addWidget(self.tree)

        detail_frame = QFrame()
        detail_frame.setFrameShape(QFrame.Shape.StyledPanel)
        detail_layout = QVBoxLayout(detail_frame)
        self.detail_title = QLabel("选择一个软件")
        self.detail_title.setFont(QFont(self.detail_title.font().family(), 14, QFont.Weight.DemiBold))
        self.detail_text = QLabel("展开左侧类别并选择软件以查看说明。")
        self.detail_text.setWordWrap(True)
        self.detail_text.setTextInteractionFlags(Qt.TextInteractionFlag.TextSelectableByMouse)
        detail_layout.addWidget(self.detail_title)
        detail_layout.addWidget(self.detail_text)
        detail_layout.addStretch()
        splitter.addWidget(detail_frame)
        splitter.setSizes([590, 330])
        root.addWidget(splitter, 1)

        footer = QHBoxLayout()
        self.selection_label = QLabel()
        footer.addWidget(self.selection_label)
        footer.addStretch()
        self.install_button = QPushButton("安装所选软件")
        self.install_button.clicked.connect(self.install_selected)
        footer.addWidget(self.install_button)
        root.addLayout(footer)

        self.populate_tree()
        self.apply_filter()

    def populate_tree(self) -> None:
        self._changing = True
        try:
            for category in self.categories:
                parent = QTreeWidgetItem(self.tree, [category.name, self.policy_text(category)])
                parent.setData(0, CATEGORY_ROLE, category.id)
                parent.setFlags(parent.flags() | Qt.ItemFlag.ItemIsUserCheckable)
                self.category_items[category.id] = parent
                for application in category.applications:
                    if application.channel == "optional-review":
                        status = "第三方候选 / 未支持"
                    else:
                        status = "已安装" if application.installed else ("推荐" if application.recommended else "可安装")
                    item = QTreeWidgetItem(parent, [application.name, status])
                    item.setData(0, APP_ROLE, application.id)
                    if application.installed:
                        item.setFlags(item.flags() & ~Qt.ItemFlag.ItemIsUserCheckable)
                        state = Qt.CheckState.Checked
                    elif not application.selectable:
                        item.setFlags(item.flags() & ~Qt.ItemFlag.ItemIsUserCheckable)
                        state = Qt.CheckState.Unchecked
                    else:
                        item.setFlags(item.flags() | Qt.ItemFlag.ItemIsUserCheckable)
                        state = Qt.CheckState.Checked if application.default_selected else Qt.CheckState.Unchecked
                    item.setCheckState(0, state)
                    self.application_items[application.id] = item
                self.enforce_initial_policy(category, parent)
                self.update_parent_state(parent)
            self.tree.expandToDepth(0)
        finally:
            self._changing = False
        self.update_selection_summary()

    @staticmethod
    def policy_text(category: CategoryEntry) -> str:
        if category.mode == "exclusive":
            return "最多选择 1 项"
        if category.mode == "bounded":
            return f"最多选择 {category.max_selected} 项"
        return "可多选"

    def enforce_initial_policy(self, category: CategoryEntry, parent: QTreeWidgetItem) -> None:
        locked_checked = sum(
            parent.child(index).checkState(0) == Qt.CheckState.Checked
            and not parent.child(index).flags() & Qt.ItemFlag.ItemIsUserCheckable
            for index in range(parent.childCount())
        )
        checked_editable = [
            parent.child(index) for index in range(parent.childCount())
            if parent.child(index).checkState(0) == Qt.CheckState.Checked
            and parent.child(index).flags() & Qt.ItemFlag.ItemIsUserCheckable
        ]
        maximum = category.max_selected
        if maximum is not None:
            available = max(0, maximum - locked_checked)
            for item in checked_editable[available:]:
                item.setCheckState(0, Qt.CheckState.Unchecked)

    def category_for_item(self, item: QTreeWidgetItem) -> CategoryEntry:
        parent = item if item.data(0, CATEGORY_ROLE) else item.parent()
        category_id = parent.data(0, CATEGORY_ROLE)
        return next(category for category in self.categories if category.id == category_id)

    def on_item_changed(self, item: QTreeWidgetItem, column: int) -> None:
        if self._changing or column != 0:
            return
        self._changing = True
        try:
            if item.data(0, CATEGORY_ROLE):
                self.toggle_category(item)
            else:
                self.enforce_leaf_policy(item)
                self.update_parent_state(item.parent())
        finally:
            self._changing = False
        self.update_selection_summary()

    def toggle_category(self, parent: QTreeWidgetItem) -> None:
        category = self.category_for_item(parent)
        select = parent.checkState(0) != Qt.CheckState.Unchecked
        editable = [
            parent.child(index) for index in range(parent.childCount())
            if parent.child(index).flags() & Qt.ItemFlag.ItemIsUserCheckable
        ]
        locked_checked = sum(
            parent.child(index).checkState(0) == Qt.CheckState.Checked
            and not parent.child(index).flags() & Qt.ItemFlag.ItemIsUserCheckable
            for index in range(parent.childCount())
        )
        limit = max(0, category.max_selected - locked_checked) if category.max_selected is not None else len(editable)
        if select and category.max_selected is not None:
            editable_checked = sum(child.checkState(0) == Qt.CheckState.Checked for child in editable)
            select = editable_checked < limit
        for index, child in enumerate(editable):
            child.setCheckState(0, Qt.CheckState.Checked if select and index < limit else Qt.CheckState.Unchecked)
        self.update_parent_state(parent)

    def enforce_leaf_policy(self, item: QTreeWidgetItem) -> None:
        if item.checkState(0) != Qt.CheckState.Checked:
            return
        category = self.category_for_item(item)
        parent = item.parent()
        checked = [parent.child(index) for index in range(parent.childCount()) if parent.child(index).checkState(0) == Qt.CheckState.Checked]
        if category.mode == "exclusive":
            locked_sibling = any(
                sibling is not item and not sibling.flags() & Qt.ItemFlag.ItemIsUserCheckable
                for sibling in checked
            )
            if locked_sibling:
                item.setCheckState(0, Qt.CheckState.Unchecked)
                self.statusBar().showMessage(f"{category.name}已有安装项，最多可选择 1 项", 5000)
                return
            for sibling in checked:
                if sibling is not item and sibling.flags() & Qt.ItemFlag.ItemIsUserCheckable:
                    sibling.setCheckState(0, Qt.CheckState.Unchecked)
        elif category.mode == "bounded" and category.max_selected is not None and len(checked) > category.max_selected:
            item.setCheckState(0, Qt.CheckState.Unchecked)
            self.statusBar().showMessage(f"{category.name}最多可选择 {category.max_selected} 项", 5000)

    def update_parent_state(self, parent: QTreeWidgetItem) -> None:
        states = [parent.child(index).checkState(0) for index in range(parent.childCount())]
        if states and all(state == Qt.CheckState.Checked for state in states):
            state = Qt.CheckState.Checked
        elif any(state == Qt.CheckState.Checked for state in states):
            state = Qt.CheckState.PartiallyChecked
        else:
            state = Qt.CheckState.Unchecked
        parent.setCheckState(0, state)

    def selected_application_ids(self) -> list[str]:
        return sorted(
            application.id for category in self.categories for application in category.applications
            if application.selectable and not application.installed and self.application_items[application.id].checkState(0) == Qt.CheckState.Checked
        )

    def update_selection_summary(self) -> None:
        count = len(self.selected_application_ids())
        installed = sum(application.installed for category in self.categories for application in category.applications)
        self.selection_label.setText(f"新安装 {count} 项　已安装 {installed} 项")
        self.install_button.setEnabled(count > 0 and self.worker is None)

    def apply_filter(self) -> None:
        mode = self.filter_box.currentData()
        for category in self.categories:
            parent = self.category_items[category.id]
            visible = False
            for application in category.applications:
                if mode == "installed":
                    hidden = not application.installed
                elif mode == "review":
                    hidden = application.channel != "optional-review"
                else:
                    hidden = application.channel != "default"
                self.application_items[application.id].setHidden(hidden)
                visible = visible or not hidden
            parent.setHidden(not visible)

    def show_details(self, current: QTreeWidgetItem | None, _previous: QTreeWidgetItem | None) -> None:
        if current is None:
            return
        application_id = current.data(0, APP_ROLE)
        if application_id:
            application = next(
                app for category in self.categories for app in category.applications if app.id == application_id
            )
            self.detail_title.setText(application.name)
            if application.channel == "optional-review":
                state = "第三方审核频道候选；当前 backend 未支持，不能安装"
            else:
                state = "已安装（Phase 1 不支持移除）" if application.installed else "尚未安装"
            default = "是" if application.default_selected else "否"
            opt_in = "需要" if application.user_opt_in_required else "不需要"
            self.detail_text.setText(
                f"{application.description}\n\n状态：{state}\n目录 ID：{application.id}\n"
                f"提供方：{application.provider}\n来源：{application.source}\n许可证：{application.license}\n"
                f"审核状态：{application.review_status}\n用户 opt-in：{opt_in}\n"
                f"频道说明：{application.availability_reason or '-'}\n默认选择：{default}"
            )
        else:
            category = self.category_for_item(current)
            self.detail_title.setText(category.name)
            self.detail_text.setText(
                f"选择规则：{self.policy_text(category)}\n\n父复选框会按此规则选择或清除可用子项；"
                "半选表示只选择了部分软件。"
            )

    def install_selected(self) -> None:
        ids = self.selected_application_ids()
        names = [self.application_items[value].text(0) for value in ids]
        try:
            transaction_dir, plan = self.backend.create_plan(ids)
        except Exception as exc:
            QMessageBox.critical(self, "无法创建安装计划", str(exc))
            return
        dialog = PlanDialog(names, plan, self)
        if dialog.exec() != QDialog.DialogCode.Accepted:
            shutil.rmtree(transaction_dir, ignore_errors=True)
            return
        self.install_button.setEnabled(False)
        self.statusBar().showMessage("正在确认并应用安装计划…")
        self.worker = ApplyThread(self.backend, transaction_dir)
        self.worker.succeeded.connect(self.install_succeeded)
        self.worker.failed.connect(self.install_failed)
        self.worker.finished.connect(self.worker_finished)
        self.worker.start()

    def install_succeeded(self, output: str) -> None:
        QMessageBox.information(self, "安装完成", output or "所选软件已安装。")

    def install_failed(self, message: str) -> None:
        QMessageBox.critical(self, "安装失败", message)

    def worker_finished(self) -> None:
        if self.worker is not None:
            self.worker.deleteLater()
        self.worker = None
        self.statusBar().clearMessage()
        self.update_selection_summary()


def main() -> int:
    application = QApplication(sys.argv)
    application.setApplicationName("Linxira Package Center")
    application.setOrganizationName("Linxira")
    catalog_path = Path(os.environ.get("LINXIRA_CATALOG_PATH", DEFAULT_CATALOG_PATH))
    components_cli = os.environ.get("LINXIRA_COMPONENTS_CLI", DEFAULT_COMPONENTS_CLI)
    state_value = os.environ.get("LINXIRA_INSTALLED_STATE_PATH")
    try:
        categories = load_catalog(catalog_path, load_installed_state(Path(state_value) if state_value else None))
    except CatalogError as exc:
        QMessageBox.critical(None, "无法打开软件中心", str(exc))
        return 1
    window = PackageCenterWindow(categories, ComponentsBackend(catalog_path, components_cli))
    window.show()
    return application.exec()


if __name__ == "__main__":
    raise SystemExit(main())
